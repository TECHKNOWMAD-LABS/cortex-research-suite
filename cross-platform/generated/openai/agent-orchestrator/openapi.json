{
  "openapi": "3.1.0",
  "info": {
    "title": "agent-orchestrator API",
    "version": "1.0.0",
    "description": "Multi-agent coordination and task dispatch with dynamic routing and load balancing."
  },
  "servers": [
    {
      "url": "https://api.techknowmad.ai/skills/agent-orchestrator"
    }
  ],
  "paths": {
    "/orchestrate_agents": {
      "post": {
        "operationId": "orchestrate_agents",
        "summary": "Coordinate multiple agents to execute tasks with dynamic routing",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "task": {
                    "type": "string",
                    "description": "Task description to orchestrate"
                  },
                  "agents": {
                    "type": "array",
                    "description": "List of agent identifiers to coordinate"
                  }
                },
                "required": [
                  "task"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  }
}