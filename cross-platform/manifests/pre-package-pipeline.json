{\n  "name": "pre-package-pipeline",\n  "version": "1.0.0",\n  "description": "Pre-packaging validation pipeline for Claude Code skills. Validates structure, checks references, verifies scripts, and ensures packaging readiness before .skill file creation.",\n  "author": "TECHKNOWMAD LABS",\n  "license": "MIT",\n  "repository": "https://github.com/TECHKNOWMAD-LABS/cortex-research-suite/tree/main/skills/pre-package-pipeline",\n  "capabilities": [\n    {\n      "name": "validate_package",\n      "description": "Run pre-packaging validation on a skill directory",\n      "input_schema": {\n        "type": "object",\n        "properties": {\n          "skill_path": {\n            "type": "string",\n            "description": "Path to skill directory"\n          },\n          "strict": {\n            "type": "boolean",\n            "default": true,\n            "description": "Fail on warnings"\n          },\n          "fix": {\n            "type": "boolean",\n            "default": false,\n            "description": "Auto-fix issues"\n          }\n        },\n        "required": [\n          "skill_path"\n        ]\n      },\n      "output_schema": {\n        "type": "object",\n        "properties": {\n          "status": {\n            "type": "string",\n            "enum": [\n              "pass",\n              "warn",\n              "fail"\n            ]\n          },\n          "checks": {\n            "type": "array",\n            "items": {\n              "type": "object"\n            }\n          },\n          "fixable": {\n            "type": "integer"\n          },\n          "report_path": {\n            "type": "string"\n          }\n        }\n      }\n    }\n  ],\n  "platforms": {\n    "claude_skill": {\n      "entry_point": "SKILL.md",\n      "triggers": [\n        "pre-packaging",\n        "validation",\n        "pipeline",\n        "claude",\n        "code",\n        "skills",\n        "validates",\n        "structure",\n        "checks",\n        "references",\n        "verifies",\n        "scripts",\n        "ensures",\n        "packaging",\n        "readiness"\n      ]\n    },\n    "mcp_server": {\n      "transport": "stdio",\n      "entry_point": "mcp/pre-package-pipeline/server.py",\n      "command": "uv",\n      "args": [\n        "--directory",\n        "mcp/pre-package-pipeline",\n        "run",\n        "python",\n        "server.py"\n      ]\n    },\n    "langchain": {\n      "tool_class": "PrePackagePipelineTool",\n      "module_path": "langchain.pre_package_pipeline.tools"\n    },\n    "crewai": {\n      "tool_class": "PrePackagePipelineTool",\n      "module_path": "crewai.pre_package_pipeline.tools"\n    },\n    "openai_gpt": {\n      "action_schema_url": "https://api.techknowmad.ai/skills/pre-package-pipeline/openapi.json",\n      "openapi_spec": "openai/pre-package-pipeline/openapi.json"\n    },\n    "github_copilot": {\n      "mcp_config": {\n        "command": "uv",\n        "args": [\n          "--directory",\n          "mcp/pre-package-pipeline",\n          "run",\n          "python",\n          "server.py"\n        ]\n      }\n    }\n  },\n  "dependencies": {\n    "python": ">=3.12",\n    "packages": [],\n    "system": []\n  }\n}