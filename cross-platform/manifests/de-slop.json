{\n  "name": "de-slop",\n  "version": "1.0.0",\n  "description": "Detects and scores AI-generated writing patterns in markdown and documentation. Scans for emoji abuse, hyperbolic language, defensive framing, buzzword stacking, and motivational fluff. Produces a 0-100 slop score.",\n  "author": "TECHKNOWMAD LABS",\n  "license": "MIT",\n  "repository": "https://github.com/TECHKNOWMAD-LABS/cortex-research-suite/tree/main/skills/de-slop",\n  "capabilities": [\n    {\n      "name": "scan_slop",\n      "description": "Scan text for AI-generated writing patterns and return a slop score with findings",\n      "input_schema": {\n        "type": "object",\n        "properties": {\n          "target": {\n            "type": "string",\n            "description": "File path or directory to scan"\n          },\n          "format": {\n            "type": "string",\n            "enum": [\n              "json",\n              "markdown",\n              "both"\n            ],\n            "default": "both"\n          },\n          "fix": {\n            "type": "boolean",\n            "default": false,\n            "description": "Auto-fix detected patterns"\n          }\n        },\n        "required": [\n          "target"\n        ]\n      },\n      "output_schema": {\n        "type": "object",\n        "properties": {\n          "score": {\n            "type": "integer",\n            "description": "Slop score 0-100 (lower is better)"\n          },\n          "categories": {\n            "type": "object"\n          },\n          "findings": {\n            "type": "array",\n            "items": {\n              "type": "object"\n            }\n          },\n          "report_path": {\n            "type": "string"\n          }\n        }\n      }\n    }\n  ],\n  "platforms": {\n    "claude_skill": {\n      "entry_point": "SKILL.md",\n      "triggers": [\n        "detects",\n        "scores",\n        "ai-generated",\n        "writing",\n        "patterns",\n        "markdown",\n        "documentation",\n        "scans",\n        "emoji",\n        "abuse",\n        "hyperbolic",\n        "language",\n        "defensive",\n        "framing",\n        "buzzword"\n      ]\n    },\n    "mcp_server": {\n      "transport": "stdio",\n      "entry_point": "mcp/de-slop/server.py",\n      "command": "uv",\n      "args": [\n        "--directory",\n        "mcp/de-slop",\n        "run",\n        "python",\n        "server.py"\n      ]\n    },\n    "langchain": {\n      "tool_class": "DeSlopTool",\n      "module_path": "langchain.de_slop.tools"\n    },\n    "crewai": {\n      "tool_class": "DeSlopTool",\n      "module_path": "crewai.de_slop.tools"\n    },\n    "openai_gpt": {\n      "action_schema_url": "https://api.techknowmad.ai/skills/de-slop/openapi.json",\n      "openapi_spec": "openai/de-slop/openapi.json"\n    },\n    "github_copilot": {\n      "mcp_config": {\n        "command": "uv",\n        "args": [\n          "--directory",\n          "mcp/de-slop",\n          "run",\n          "python",\n          "server.py"\n        ]\n      }\n    }\n  },\n  "dependencies": {\n    "python": ">=3.12",\n    "packages": [],\n    "system": []\n  }\n}