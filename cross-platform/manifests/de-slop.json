{
  "name": "de-slop",
  "version": "1.0.0",
  "description": "Detects and scores AI-generated writing patterns in markdown and documentation. Scans for emoji abuse, hyperbolic language, defensive framing, buzzword stacking, and motivational fluff. Produces a 0-100 slop score.",
  "author": "TECHKNOWMAD LABS",
  "license": "MIT",
  "repository": "https://github.com/TECHKNOWMAD-LABS/cortex/tree/main/skills/de-slop",
  "capabilities": [
    {
      "name": "scan_slop",
      "description": "Scan text for AI-generated writing patterns and return a slop score with findings",
      "input_schema": {
        "type": "object",
        "properties": {
          "target": {
            "type": "string",
            "description": "File path or directory to scan"
          },
          "format": {
            "type": "string",
            "enum": [
              "json",
              "markdown",
              "both"
            ],
            "default": "both"
          },
          "fix": {
            "type": "boolean",
            "default": false,
            "description": "Auto-fix detected patterns"
          }
        },
        "required": [
          "target"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "score": {
            "type": "integer",
            "description": "Slop score 0-100 (lower is better)"
          },
          "categories": {
            "type": "object"
          },
          "findings": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "report_path": {
            "type": "string"
          }
        }
      }
    }
  ],
  "platforms": {
    "claude_skill": {
      "entry_point": "SKILL.md",
      "triggers": [
        "detects",
        "scores",
        "ai-generated",
        "writing",
        "patterns",
        "markdown",
        "documentation",
        "scans",
        "emoji",
        "abuse",
        "hyperbolic",
        "language",
        "defensive",
        "framing",
        "buzzword"
      ]
    },
    "mcp_server": {
      "transport": "stdio",
      "entry_point": "mcp/de-slop/server.py",
      "command": "uv",
      "args": [
        "--directory",
        "mcp/de-slop",
        "run",
        "python",
        "server.py"
      ]
    },
    "langchain": {
      "tool_class": "DeSlopTool",
      "module_path": "langchain.de_slop.tools"
    },
    "crewai": {
      "tool_class": "DeSlopTool",
      "module_path": "crewai.de_slop.tools"
    },
    "openai_gpt": {
      "action_schema_url": "https://api.techknowmad.ai/skills/de-slop/openapi.json",
      "openapi_spec": "openai/de-slop/openapi.json"
    },
    "github_copilot": {
      "mcp_config": {
        "command": "uv",
        "args": [
          "--directory",
          "mcp/de-slop",
          "run",
          "python",
          "server.py"
        ]
      }
    }
  },
  "dependencies": {
    "python": ">=3.12",
    "packages": [],
    "system": []
  }
}