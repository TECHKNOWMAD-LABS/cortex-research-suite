{\n  "name": "agent-output-validator",\n  "version": "1.0.0",\n  "description": "Validates AI agent outputs against schema contracts, quality thresholds, and safety constraints. Catches hallucinations, schema violations, and drift before outputs reach production.",\n  "author": "TECHKNOWMAD LABS",\n  "license": "MIT",\n  "repository": "https://github.com/TECHKNOWMAD-LABS/cortex-research-suite/tree/main/skills/agent-output-validator",\n  "capabilities": [\n    {\n      "name": "validate_output",\n      "description": "Validate an agent's output against schema, quality, and safety constraints",\n      "input_schema": {\n        "type": "object",\n        "properties": {\n          "output": {\n            "type": "object",\n            "description": "Agent output to validate"\n          },\n          "schema": {\n            "type": "object",\n            "description": "Expected output schema"\n          },\n          "quality_threshold": {\n            "type": "number",\n            "default": 0.8,\n            "description": "Minimum quality score (0-1)"\n          },\n          "safety_checks": {\n            "type": "boolean",\n            "default": true,\n            "description": "Run safety constraint checks"\n          }\n        },\n        "required": [\n          "output"\n        ]\n      },\n      "output_schema": {\n        "type": "object",\n        "properties": {\n          "valid": {\n            "type": "boolean"\n          },\n          "score": {\n            "type": "number"\n          },\n          "violations": {\n            "type": "array",\n            "items": {\n              "type": "object"\n            }\n          },\n          "suggestions": {\n            "type": "array",\n            "items": {\n              "type": "string"\n            }\n          }\n        }\n      }\n    }\n  ],\n  "platforms": {\n    "claude_skill": {\n      "entry_point": "SKILL.md",\n      "triggers": [\n        "validates",\n        "agent",\n        "outputs",\n        "schema",\n        "contracts",\n        "quality",\n        "thresholds",\n        "safety",\n        "constraints",\n        "catches",\n        "hallucinations",\n        "violations",\n        "drift",\n        "reach",\n        "production"\n      ]\n    },\n    "mcp_server": {\n      "transport": "stdio",\n      "entry_point": "mcp/agent-output-validator/server.py",\n      "command": "uv",\n      "args": [\n        "--directory",\n        "mcp/agent-output-validator",\n        "run",\n        "python",\n        "server.py"\n      ]\n    },\n    "langchain": {\n      "tool_class": "AgentOutputValidatorTool",\n      "module_path": "langchain.agent_output_validator.tools"\n    },\n    "crewai": {\n      "tool_class": "AgentOutputValidatorTool",\n      "module_path": "crewai.agent_output_validator.tools"\n    },\n    "openai_gpt": {\n      "action_schema_url": "https://api.techknowmad.ai/skills/agent-output-validator/openapi.json",\n      "openapi_spec": "openai/agent-output-validator/openapi.json"\n    },\n    "github_copilot": {\n      "mcp_config": {\n        "command": "uv",\n        "args": [\n          "--directory",\n          "mcp/agent-output-validator",\n          "run",\n          "python",\n          "server.py"\n        ]\n      }\n    }\n  },\n  "dependencies": {\n    "python": ">=3.12",\n    "packages": [],\n    "system": []\n  }\n}