{\n  "name": "design-system-forge",\n  "version": "1.0.0",\n  "description": "Generates complete design systems from brand parameters. Creates tokens, component specs, documentation, and theme configurations with accessibility compliance built in.",\n  "author": "TECHKNOWMAD LABS",\n  "license": "MIT",\n  "repository": "https://github.com/TECHKNOWMAD-LABS/cortex-research-suite/tree/main/skills/design-system-forge",\n  "capabilities": [\n    {\n      "name": "generate_design_system",\n      "description": "Generate a complete design system from brand parameters",\n      "input_schema": {\n        "type": "object",\n        "properties": {\n          "brand": {\n            "type": "object",\n            "description": "Brand parameters (colors, typography, spacing)"\n          },\n          "components": {\n            "type": "array",\n            "items": {\n              "type": "string"\n            },\n            "description": "Components to generate"\n          },\n          "output_dir": {\n            "type": "string",\n            "description": "Output directory for generated system"\n          },\n          "format": {\n            "type": "string",\n            "enum": [\n              "css",\n              "tailwind",\n              "styled-components",\n              "all"\n            ],\n            "default": "all"\n          }\n        },\n        "required": [\n          "brand"\n        ]\n      },\n      "output_schema": {\n        "type": "object",\n        "properties": {\n          "tokens": {\n            "type": "object"\n          },\n          "components": {\n            "type": "array",\n            "items": {\n              "type": "object"\n            }\n          },\n          "output_path": {\n            "type": "string"\n          },\n          "accessibility_score": {\n            "type": "number"\n          }\n        }\n      }\n    }\n  ],\n  "platforms": {\n    "claude_skill": {\n      "entry_point": "SKILL.md",\n      "triggers": [\n        "generates",\n        "complete",\n        "design",\n        "systems",\n        "brand",\n        "parameters",\n        "creates",\n        "tokens",\n        "component",\n        "specs",\n        "documentation",\n        "theme",\n        "configurations",\n        "accessibility",\n        "compliance"\n      ]\n    },\n    "mcp_server": {\n      "transport": "stdio",\n      "entry_point": "mcp/design-system-forge/server.py",\n      "command": "uv",\n      "args": [\n        "--directory",\n        "mcp/design-system-forge",\n        "run",\n        "python",\n        "server.py"\n      ]\n    },\n    "langchain": {\n      "tool_class": "DesignSystemForgeTool",\n      "module_path": "langchain.design_system_forge.tools"\n    },\n    "crewai": {\n      "tool_class": "DesignSystemForgeTool",\n      "module_path": "crewai.design_system_forge.tools"\n    },\n    "openai_gpt": {\n      "action_schema_url": "https://api.techknowmad.ai/skills/design-system-forge/openapi.json",\n      "openapi_spec": "openai/design-system-forge/openapi.json"\n    },\n    "github_copilot": {\n      "mcp_config": {\n        "command": "uv",\n        "args": [\n          "--directory",\n          "mcp/design-system-forge",\n          "run",\n          "python",\n          "server.py"\n        ]\n      }\n    }\n  },\n  "dependencies": {\n    "python": ">=3.12",\n    "packages": [],\n    "system": []\n  }\n}