{
  "name": "session-memory",
  "version": "1.0.0",
  "description": "Lightweight session-scoped memory with checkpoint and restore. Captures working state snapshots that persist across context window resets within a single session.",
  "author": "TECHKNOWMAD LABS",
  "license": "MIT",
  "repository": "https://github.com/TECHKNOWMAD-LABS/cortex/tree/main/skills/session-memory",
  "capabilities": [
    {
      "name": "session_checkpoint",
      "description": "Create, restore, or list session memory checkpoints",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "save",
              "restore",
              "list",
              "delete"
            ]
          },
          "checkpoint_id": {
            "type": "string",
            "description": "Checkpoint identifier"
          },
          "data": {
            "type": "object",
            "description": "State data to checkpoint"
          }
        },
        "required": [
          "action"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "checkpoint_id": {
            "type": "string"
          },
          "data": {
            "type": "object"
          },
          "checkpoints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  ],
  "platforms": {
    "claude_skill": {
      "entry_point": "SKILL.md",
      "triggers": [
        "lightweight",
        "session-scoped",
        "memory",
        "checkpoint",
        "restore",
        "captures",
        "working",
        "state",
        "snapshots",
        "persist",
        "context",
        "window",
        "resets",
        "within",
        "session"
      ]
    },
    "mcp_server": {
      "transport": "stdio",
      "entry_point": "mcp/session-memory/server.py",
      "command": "uv",
      "args": [
        "--directory",
        "mcp/session-memory",
        "run",
        "python",
        "server.py"
      ]
    },
    "langchain": {
      "tool_class": "SessionMemoryTool",
      "module_path": "langchain.session_memory.tools"
    },
    "crewai": {
      "tool_class": "SessionMemoryTool",
      "module_path": "crewai.session_memory.tools"
    },
    "openai_gpt": {
      "action_schema_url": "https://api.techknowmad.ai/skills/session-memory/openapi.json",
      "openapi_spec": "openai/session-memory/openapi.json"
    },
    "github_copilot": {
      "mcp_config": {
        "command": "uv",
        "args": [
          "--directory",
          "mcp/session-memory",
          "run",
          "python",
          "server.py"
        ]
      }
    }
  },
  "dependencies": {
    "python": ">=3.12",
    "packages": [],
    "system": []
  }
}