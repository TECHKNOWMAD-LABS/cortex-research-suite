{\n  "name": "code-review-engine",\n  "version": "1.0.0",\n  "description": "Automated code review with multi-dimensional analysis: correctness, security, performance, maintainability, and style. Produces structured findings with severity, location, and suggested fixes.",\n  "author": "TECHKNOWMAD LABS",\n  "license": "MIT",\n  "repository": "https://github.com/TECHKNOWMAD-LABS/cortex-research-suite/tree/main/skills/code-review-engine",\n  "capabilities": [\n    {\n      "name": "review_code",\n      "description": "Run automated code review on a file or directory with multi-dimensional analysis",\n      "input_schema": {\n        "type": "object",\n        "properties": {\n          "target": {\n            "type": "string",\n            "description": "File or directory path to review"\n          },\n          "language": {\n            "type": "string",\n            "description": "Programming language (auto-detected if omitted)"\n          },\n          "dimensions": {\n            "type": "array",\n            "items": {\n              "type": "string",\n              "enum": [\n                "correctness",\n                "security",\n                "performance",\n                "maintainability",\n                "style"\n              ]\n            },\n            "description": "Review dimensions to check"\n          },\n          "severity_threshold": {\n            "type": "string",\n            "enum": [\n              "critical",\n              "high",\n              "medium",\n              "low"\n            ],\n            "default": "low"\n          }\n        },\n        "required": [\n          "target"\n        ]\n      },\n      "output_schema": {\n        "type": "object",\n        "properties": {\n          "status": {\n            "type": "string",\n            "enum": [\n              "pass",\n              "warn",\n              "fail"\n            ]\n          },\n          "findings": {\n            "type": "array",\n            "items": {\n              "type": "object"\n            }\n          },\n          "summary": {\n            "type": "object"\n          },\n          "score": {\n            "type": "number"\n          }\n        }\n      }\n    }\n  ],\n  "platforms": {\n    "claude_skill": {\n      "entry_point": "SKILL.md",\n      "triggers": [\n        "code",\n        "review",\n        "multi-dimensional",\n        "analysis",\n        "correctness",\n        "security",\n        "performance",\n        "maintainability",\n        "style",\n        "findings",\n        "severity",\n        "location",\n        "suggested",\n        "fixes"\n      ]\n    },\n    "mcp_server": {\n      "transport": "stdio",\n      "entry_point": "mcp/code-review-engine/server.py",\n      "command": "uv",\n      "args": [\n        "--directory",\n        "mcp/code-review-engine",\n        "run",\n        "python",\n        "server.py"\n      ]\n    },\n    "langchain": {\n      "tool_class": "CodeReviewEngineTool",\n      "module_path": "langchain.code_review_engine.tools"\n    },\n    "crewai": {\n      "tool_class": "CodeReviewEngineTool",\n      "module_path": "crewai.code_review_engine.tools"\n    },\n    "openai_gpt": {\n      "action_schema_url": "https://api.techknowmad.ai/skills/code-review-engine/openapi.json",\n      "openapi_spec": "openai/code-review-engine/openapi.json"\n    },\n    "github_copilot": {\n      "mcp_config": {\n        "command": "uv",\n        "args": [\n          "--directory",\n          "mcp/code-review-engine",\n          "run",\n          "python",\n          "server.py"\n        ]\n      }\n    }\n  },\n  "dependencies": {\n    "python": ">=3.12",\n    "packages": [],\n    "system": []\n  }\n}