{\n  "name": "prompt-architect",\n  "version": "1.0.0",\n  "description": "Prompt engineering and optimization. Analyzes, improves, and tests prompts for AI/ML tasks and agent systems.",\n  "author": "TECHKNOWMAD LABS",\n  "license": "MIT",\n  "repository": "https://github.com/TECHKNOWMAD-LABS/cortex-research-suite/tree/main/skills/prompt-architect",\n  "capabilities": [\n    {\n      "name": "optimize_prompt",\n      "description": "Analyze and optimize a prompt for improved performance",\n      "input_schema": {\n        "type": "object",\n        "properties": {\n          "prompt": {\n            "type": "string",\n            "description": "Prompt to optimize"\n          },\n          "task_type": {\n            "type": "string",\n            "description": "Type of task the prompt is for"\n          },\n          "model": {\n            "type": "string",\n            "description": "Target model"\n          }\n        },\n        "required": [\n          "prompt"\n        ]\n      }\n    }\n  ],\n  "platforms": {\n    "claude_skill": {\n      "entry_point": "SKILL.md"\n    },\n    "mcp_server": {\n      "transport": "stdio",\n      "entry_point": "mcp/prompt-architect/server.py",\n      "command": "uv",\n      "args": [\n        "--directory",\n        "mcp/prompt-architect",\n        "run",\n        "python",\n        "server.py"\n      ]\n    },\n    "langchain": {\n      "tool_class": "Optimize_promptTool",\n      "module_path": "langchain.prompt_architect.tools"\n    },\n    "crewai": {\n      "tool_class": "Optimize_promptTool",\n      "module_path": "crewai.prompt_architect.tools"\n    },\n    "openai_gpt": {\n      "action_schema_url": "https://api.techknowmad.ai/skills/prompt-architect/openapi.json",\n      "openapi_spec": "openai/prompt-architect/openapi.json"\n    },\n    "github_copilot": {\n      "mcp_config": {\n        "command": "uv",\n        "args": [\n          "--directory",\n          "mcp/prompt-architect",\n          "run",\n          "python",\n          "server.py"\n        ]\n      }\n    }\n  },\n  "dependencies": {\n    "python": ">=3.12",\n    "packages": []\n  }\n}