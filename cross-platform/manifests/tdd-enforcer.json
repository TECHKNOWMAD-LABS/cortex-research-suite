{\n  "name": "tdd-enforcer",\n  "version": "1.0.0",\n  "description": "Enforces test-driven development workflow. Validates that tests exist before implementation, checks coverage thresholds, detects test anti-patterns, and blocks commits without adequate test coverage.",\n  "author": "TECHKNOWMAD LABS",\n  "license": "MIT",\n  "repository": "https://github.com/TECHKNOWMAD-LABS/cortex-research-suite/tree/main/skills/tdd-enforcer",\n  "capabilities": [\n    {\n      "name": "enforce_tdd",\n      "description": "Validate TDD compliance for a codebase — tests exist, coverage meets threshold, no anti-patterns",\n      "input_schema": {\n        "type": "object",\n        "properties": {\n          "target": {\n            "type": "string",\n            "description": "Path to codebase"\n          },\n          "coverage_threshold": {\n            "type": "number",\n            "default": 80,\n            "description": "Minimum coverage percentage"\n          },\n          "check_anti_patterns": {\n            "type": "boolean",\n            "default": true\n          },\n          "block_commit": {\n            "type": "boolean",\n            "default": false,\n            "description": "Return exit code for pre-commit hook"\n          }\n        },\n        "required": [\n          "target"\n        ]\n      },\n      "output_schema": {\n        "type": "object",\n        "properties": {\n          "compliant": {\n            "type": "boolean"\n          },\n          "coverage": {\n            "type": "number"\n          },\n          "anti_patterns": {\n            "type": "array",\n            "items": {\n              "type": "object"\n            }\n          },\n          "missing_tests": {\n            "type": "array",\n            "items": {\n              "type": "string"\n            }\n          },\n          "report": {\n            "type": "object"\n          }\n        }\n      }\n    }\n  ],\n  "platforms": {\n    "claude_skill": {\n      "entry_point": "SKILL.md",\n      "triggers": [\n        "enforces",\n        "test-driven",\n        "development",\n        "workflow",\n        "validates",\n        "tests",\n        "exist",\n        "implementation",\n        "checks",\n        "coverage",\n        "thresholds",\n        "detects",\n        "test",\n        "anti-patterns",\n        "blocks"\n      ]\n    },\n    "mcp_server": {\n      "transport": "stdio",\n      "entry_point": "mcp/tdd-enforcer/server.py",\n      "command": "uv",\n      "args": [\n        "--directory",\n        "mcp/tdd-enforcer",\n        "run",\n        "python",\n        "server.py"\n      ]\n    },\n    "langchain": {\n      "tool_class": "TddEnforcerTool",\n      "module_path": "langchain.tdd_enforcer.tools"\n    },\n    "crewai": {\n      "tool_class": "TddEnforcerTool",\n      "module_path": "crewai.tdd_enforcer.tools"\n    },\n    "openai_gpt": {\n      "action_schema_url": "https://api.techknowmad.ai/skills/tdd-enforcer/openapi.json",\n      "openapi_spec": "openai/tdd-enforcer/openapi.json"\n    },\n    "github_copilot": {\n      "mcp_config": {\n        "command": "uv",\n        "args": [\n          "--directory",\n          "mcp/tdd-enforcer",\n          "run",\n          "python",\n          "server.py"\n        ]\n      }\n    }\n  },\n  "dependencies": {\n    "python": ">=3.12",\n    "packages": [],\n    "system": []\n  }\n}