{\n  "name": "repo-publisher",\n  "version": "1.0.0",\n  "description": "Pre-publish pipeline for GitHub repositories. Chains security scanning, AI slop detection, structure validation, and repo metadata updates into a single workflow.",\n  "author": "TECHKNOWMAD LABS",\n  "license": "MIT",\n  "repository": "https://github.com/TECHKNOWMAD-LABS/cortex-research-suite/tree/main/skills/repo-publisher",\n  "capabilities": [\n    {\n      "name": "publish_repo",\n      "description": "Run the full pre-publish pipeline on a repository",\n      "input_schema": {\n        "type": "object",\n        "properties": {\n          "repo_path": {\n            "type": "string",\n            "description": "Path to repository"\n          },\n          "owner": {\n            "type": "string",\n            "description": "GitHub owner/org"\n          },\n          "repo": {\n            "type": "string",\n            "description": "Repository name"\n          },\n          "dry_run": {\n            "type": "boolean",\n            "default": false\n          }\n        },\n        "required": [\n          "repo_path"\n        ]\n      },\n      "output_schema": {\n        "type": "object",\n        "properties": {\n          "status": {\n            "type": "string",\n            "enum": [\n              "pass",\n              "warn",\n              "fail"\n            ]\n          },\n          "stages": {\n            "type": "array",\n            "items": {\n              "type": "object"\n            }\n          },\n          "publish_url": {\n            "type": "string"\n          }\n        }\n      }\n    }\n  ],\n  "platforms": {\n    "claude_skill": {\n      "entry_point": "SKILL.md",\n      "triggers": [\n        "pre-publish",\n        "pipeline",\n        "github",\n        "repositories",\n        "chains",\n        "security",\n        "scanning",\n        "slop",\n        "detection",\n        "structure",\n        "validation",\n        "repo",\n        "metadata",\n        "updates",\n        "workflow"\n      ]\n    },\n    "mcp_server": {\n      "transport": "stdio",\n      "entry_point": "mcp/repo-publisher/server.py",\n      "command": "uv",\n      "args": [\n        "--directory",\n        "mcp/repo-publisher",\n        "run",\n        "python",\n        "server.py"\n      ]\n    },\n    "langchain": {\n      "tool_class": "RepoPublisherTool",\n      "module_path": "langchain.repo_publisher.tools"\n    },\n    "crewai": {\n      "tool_class": "RepoPublisherTool",\n      "module_path": "crewai.repo_publisher.tools"\n    },\n    "openai_gpt": {\n      "action_schema_url": "https://api.techknowmad.ai/skills/repo-publisher/openapi.json",\n      "openapi_spec": "openai/repo-publisher/openapi.json"\n    },\n    "github_copilot": {\n      "mcp_config": {\n        "command": "uv",\n        "args": [\n          "--directory",\n          "mcp/repo-publisher",\n          "run",\n          "python",\n          "server.py"\n        ]\n      }\n    }\n  },\n  "dependencies": {\n    "python": ">=3.12",\n    "packages": [],\n    "system": []\n  }\n}